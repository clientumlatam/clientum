NODE_ENV=production
SERVER_PORT=3000

# Base de datos
# Generar password con: openssl rand -hex 16
DATABASE_CONNECTION_URI=postgresql://evolution:CAMBIA_ESTE_PASSWORD@localhost:5432/evolution

# Auth
AUTHENTICATION_TYPE=apikey
# Generar con: openssl rand -hex 32
AUTHENTICATION_API_KEY=

# Webhook → Clientum (URL pública via Cloudflare Tunnel)
WEBHOOK_GLOBAL_URL=https://TU_DOMINIO/api/chatbot/webhook
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_MESSAGES_UPDATE=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true

# Baileys (sin Meta API, gratis)
WA_BUSINESS_ID_DEFAULT=
